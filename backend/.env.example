DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-in-dev-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Postgres or local Docker: postgres://entercom:entercom@localhost:5432/entercom
DATABASE_URL=postgres://entercom:entercom@localhost:5432/entercom

REDIS_URL=redis://localhost:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT lifetimes (seconds) — tune per environment
ACCESS_TOKEN_LIFETIME_SECONDS=900
REFRESH_TOKEN_LIFETIME_SECONDS=604800

# OpenAPI UI (disable in production if desired)
ENABLE_SPECTACULAR=True

# Supabase Storage (future uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Paystack (future — never expose secret to clients)
PAYSTACK_SECRET_KEY=
